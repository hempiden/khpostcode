# ==============================================================================
#                 CAMBODIA POSTAL CODE SYSTEM - SYSTEM CONFIGURATION
# ==============================================================================
# This file documents all system environment variables supported by the application.
# All elements are entirely optional and can also be fully customized/edited directly 
# inside the interactive administrative settings console in the frontend user interface.

# ------------------------------------------------------------------------------
# 1. CORE GEMINI AI PARSING GATEWAY
# ------------------------------------------------------------------------------
# Required for unstructured free-text normalization, batch addresses OCR, and 
# automatic Cambodian commune/district mapping intelligence.
GEMINI_API_KEY="AIzaSy..."

# ------------------------------------------------------------------------------
# 2. CLIENT WEB HOSTING & REDIRECT LINKS
# ------------------------------------------------------------------------------
# Injected dynamically by developers to establish self-referential absolute URLs.
APP_URL="https://your-active-applet.run.app"

# ------------------------------------------------------------------------------
# 3. SECURE CENTRAL RECORD STORE (SUPABASE CLOUD REST ENGINE)
# ------------------------------------------------------------------------------
# If left empty, the application safely defaults to a fast offline local file cache (1,653 records)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_KEY="your-supabase-service-role-or-anon-key"
SUPABASE_TABLE_NAME="cambodia_postcode_migration"

# Alternative variable names utilized for client frameworks or auto-provisioned hosts:
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"

# ------------------------------------------------------------------------------
# 4. GOOGLE MAPS PLATFORM (INTERACTIVE GEOSPATIAL SEARCH)
# ------------------------------------------------------------------------------
# Used for live map rendering, pinpoint lookup visualization, and geographic coordinate mapping.
VITE_GOOGLE_MAPS_KEY="AIzaSy..."
VITE_GOOGLE_MAPS_ID="DEMO_MAP_ID"
